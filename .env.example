COMPOSE_PROJECT_NAME=coachos
COACHOS_DOMAIN=localhost
COACHOS_SCHEME=https

JWT_SECRET_KEY=replace-with-at-least-32-random-characters
AUTH_DB_PASSWORD=replace-auth-db-password
ATHLETE_DB_PASSWORD=replace-athlete-db-password
MEDIA_DB_PASSWORD=replace-media-db-password
AI_REVIEW_DB_PASSWORD=replace-ai-review-db-password
MINIO_ROOT_USER=replace-minio-user
MINIO_ROOT_PASSWORD=replace-minio-password
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-grafana-password
OPENAI_API_KEY=

AUTH_TO_ATHLETE_TOKEN=replace-auth-to-athlete-token
ATHLETE_TO_AUTH_TOKEN=replace-athlete-to-auth-token
ATHLETE_TO_AI_TOKEN=replace-athlete-to-ai-token
ATHLETE_TO_MEDIA_TOKEN=replace-athlete-to-media-token
MEDIA_TO_ATHLETE_TOKEN=replace-media-to-athlete-token
AI_TO_ATHLETE_TOKEN=replace-ai-to-athlete-token

AUTH_IMAGE=ghcr.io/your-org/coachos-auth-service:latest
ATHLETE_IMAGE=ghcr.io/your-org/coachos-athlete-service:latest
MEDIA_IMAGE=ghcr.io/your-org/coachos-media-service:latest
AI_REVIEW_IMAGE=ghcr.io/your-org/coachos-ai-review-service:latest
FRONTEND_IMAGE=ghcr.io/your-org/coachos-frontend:latest

BACKUP_RETENTION_DAYS=14
DEPLOY_HEALTH_TIMEOUT_SECONDS=180
